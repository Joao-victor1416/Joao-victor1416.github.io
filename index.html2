let currentSchema='auto';
let currentTab='errors';
let lastResult=null;
const SCHEMA_NAMES={auto:'Detecção automática',abrasf:'NFS-e ABRASF v1/v2',tx2:'TX2 São Paulo',tecnonfse:'TecnoNFSe TX2'};

/* =========================================================
   UI
   ========================================================= */
const xmlArea=document.getElementById('xmlArea');
const clearBtn=document.getElementById('clearBtn');
const valBtn=document.getElementById('valBtn');
const resultsPanel=document.getElementById('resultsPanel');

xmlArea.addEventListener('input',()=>{
  const has=xmlArea.value.trim().length>0;
  valBtn.disabled=!has;
  clearBtn.style.display=has?'':'none';
});
xmlArea.addEventListener('keydown',e=>{
  if((e.ctrlKey||e.metaKey)&&e.key==='Enter'){e.preventDefault();if(!valBtn.disabled)runValidation();}
});

function clearAll(){xmlArea.value='';valBtn.disabled=true;clearBtn.style.display='none';lastResult=null;renderIdle();}

function loadSample(type){
  xmlArea.value=type==='tx2'?SAMPLE_TX2:type==='tecnonfse'?SAMPLE_TECNONFSE:SAMPLE_ABRASF;
  setSchema(document.querySelector('[data-schema="'+type+'"]'));
  valBtn.disabled=false;
  clearBtn.style.display='';
}

function setSchema(btn){
  document.querySelectorAll('.schema-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  currentSchema=btn.dataset.schema;
}

function setTab(tab){
  currentTab=tab;
  if(lastResult)renderResults(lastResult);
}

function runValidation(){
  if(!xmlArea.value.trim())return;
  valBtn.disabled=true;
  valBtn.innerHTML='<span class="spin">↻</span> Validando...';
  setTimeout(()=>{
    try{
      lastResult=doValidate(xmlArea.value,currentSchema);
      currentTab=lastResult.stats.e>0?'errors':lastResult.stats.w>0?'warnings':'info';
      renderResults(lastResult);
    }catch(err){
      renderError('Erro interno: '+err.message);
    }
    valBtn.disabled=false;
    valBtn.innerHTML='<svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> Validar XML';
  },80);
}

function renderIdle(){
  resultsPanel.innerHTML=`<div class="result-idle">
    <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    <p>Aguardando validação</p>
    <small>Cole um XML ou carregue um arquivo e clique em Validar</small>
  </div>`;
}

function renderError(msg){
  renderResults({valid:false,detected:'unknown',used:'unknown',errs:[{t:'e',code:'ERRO',field:'/',msg}],warns:[],info:[],stats:{e:1,w:0,i:0}});
}

function esc(s){return s?s.toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'):''}

function renderResults(r){
  const items=currentTab==='errors'?r.errs:currentTab==='warnings'?r.warns:r.info;
  const usedName=SCHEMA_NAMES[r.used]||r.used||'desconhecido';
  const detectedName=SCHEMA_NAMES[r.detected]||r.detected;
  const schemaInfo=usedName+(r.detected&&r.detected!==r.used?' (detectado: '+detectedName+')':'');

  resultsPanel.innerHTML=`
    <div class="status-banner ${r.valid?'valid':'invalid'}">
      <div class="status-icon ${r.valid?'valid':'invalid'}">
        ${r.valid
          ?'<svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
          :'<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>'}
      </div>
      <div>
        <div class="status-title ${r.valid?'valid':'invalid'}">${r.valid?'XML VÁLIDO':'XML COM ERROS'}</div>
        <div class="status-sub">Schema: ${esc(schemaInfo)}</div>
      </div>
      <div class="counters">
        <div class="counter"><div class="counter-num e">${r.stats.e}</div><div class="counter-lbl">Erros</div></div>
        <div class="counter"><div class="counter-num w">${r.stats.w}</div><div class="counter-lbl">Avisos</div></div>
        <div class="counter"><div class="counter-num i">${r.stats.i}</div><div class="counter-lbl">Info</div></div>
      </div>
    </div>
    <div class="tabs">
      <button class="tab${currentTab==='errors'?' active e':''}" onclick="setTab('errors')">✗ Erros (${r.stats.e})</button>
      <button class="tab${currentTab==='warnings'?' active w':''}" onclick="setTab('warnings')">⚠ Avisos (${r.stats.w})</button>
      <button class="tab${currentTab==='info'?' active i':''}" onclick="setTab('info')">ℹ Info (${r.stats.i})</button>
    </div>
    <div class="items">
      ${items.length===0
        ?'<div class="empty-tab">Nenhum item nesta categoria</div>'
        :items.map(it=>{
          const cl=it.t==='e'?'e':it.t==='w'?'w':'i';
          return`<div class="item ${cl}">
            <div class="item-dot"></div>
            <div class="item-body">
              <div class="item-msg">${esc(it.msg)}</div>
              ${it.field?`<div class="item-field">📍 ${esc(it.field)}</div>`:''}
            </div>
            ${it.code?`<span class="item-code ${cl}">${esc(it.code)}</span>`:''}
          </div>`;
        }).join('')}
    </div>
    <button class="copy-btn" onclick="copyReport()">
      <svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
      Copiar relatório completo
    </button>`;
}

function copyReport(){
  if(!lastResult)return;
  const r=lastResult;
  const lines=[
    '=== RELATÓRIO DE VALIDAÇÃO NFS-e / TX2 ===',
    'Data/Hora: '+new Date().toLocaleString('pt-BR'),
    'Status: '+(r.valid?'VÁLIDO':'INVÁLIDO'),
    'Schema: '+(SCHEMA_NAMES[r.used]||r.used),
    'Erros: '+r.stats.e+' | Avisos: '+r.stats.w+' | Info: '+r.stats.i,
    ''
  ];
  if(r.errs.length){lines.push('--- ERROS ('+r.errs.length+') ---');r.errs.forEach(e=>lines.push('['+e.code+'] '+e.msg+(e.field?'\n  Campo: '+e.field:'')));lines.push('');}
  if(r.warns.length){lines.push('--- AVISOS ('+r.warns.length+') ---');r.warns.forEach(w=>lines.push('['+(w.code||'WARN')+'] '+w.msg+(w.field?'\n  Campo: '+w.field:'')));lines.push('');}
  if(r.info.length){lines.push('--- INFORMAÇÕES ('+r.info.length+') ---');r.info.forEach(i=>lines.push(i.msg));}
  navigator.clipboard.writeText(lines.join('\n')).then(()=>{
    const btn=resultsPanel.querySelector('.copy-btn');
    if(btn){btn.textContent='✓ Copiado!';setTimeout(()=>{btn.innerHTML='<svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copiar relatório completo';},2000);}
  });
}

/* =========================================================
   DRAG & DROP
   ========================================================= */
const dropZone=document.getElementById('dropZone');
const fileInput=document.getElementById('fileInput');
dropZone.addEventListener('click',()=>fileInput.click());
dropZone.addEventListener('dragover',e=>{e.preventDefault();dropZone.classList.add('drag');});
dropZone.addEventListener('dragleave',()=>dropZone.classList.remove('drag'));
dropZone.addEventListener('drop',e=>{
  e.preventDefault();dropZone.classList.remove('drag');
  const f=e.dataTransfer.files[0];
  if(f&&(f.name.endsWith('.xml')||f.name.endsWith('.txt')||f.type.includes('xml')||f.type.includes('text'))){
    const rd=new FileReader();
    rd.onload=ev=>{xmlArea.value=ev.target.result;valBtn.disabled=false;clearBtn.style.display='';};
    rd.readAsText(f,'UTF-8');
  }
});
fileInput.addEventListener('change',e=>{
  const f=e.target.files[0];
  if(f){const rd=new FileReader();rd.onload=ev=>{xmlArea.value=ev.target.result;valBtn.disabled=false;clearBtn.style.display='';};rd.readAsText(f,'UTF-8');}
});
</script>
</body>
</html>
